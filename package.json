{
  "name": "andon-system",
  "version": "1.0.0",
  "description": "Sistema de Andón con alertas visuales, sonido y cronómetro",
  "main": "src/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "start": "electron .",
    "dist": "electron-builder --publish never"
  },
  "keywords": ["andon", "alerts", "manufacturing"],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "@azure/identity": "^3.0.0",
    "axios": "^1.6.0",
    "dotenv": "^16.3.1",
    "electron-is-dev": "^2.0.0"
  },
  "build": {
    "appId": "com.andon.system",
    "productName": "Andón System",
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": ["nsis", "portable"]
    }
  }
}
